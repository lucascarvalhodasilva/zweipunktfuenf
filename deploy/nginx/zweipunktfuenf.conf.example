# HTTP → HTTPS redirect (Certbot manages the actual redirect block)
server {
  listen 80;
  listen [::]:80;
  server_name zweipunktfuenf.de www.zweipunktfuenf.de;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl;
  listen [::]:443 ssl ipv6only=on;
  http2 on;
  server_name zweipunktfuenf.de www.zweipunktfuenf.de;

  ssl_certificate /etc/letsencrypt/live/zweipunktfuenf.de/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/zweipunktfuenf.de/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  gzip on;
  gzip_types text/plain text/css application/javascript application/json image/svg+xml application/xml;
  gzip_min_length 1024;
  gzip_vary on;

  # Long-lived cache for immutable Next.js static assets
  location /_next/static/ {
    proxy_pass http://127.0.0.1:4000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    add_header Cache-Control "public, max-age=31536000, immutable";
  }

  location / {
    proxy_pass http://127.0.0.1:4000;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }
}